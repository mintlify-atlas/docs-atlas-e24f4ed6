  "keyFeatures": [
    "Multi-version support (MC 1.2.5 - 1.21.x)",
    "GUI menu system",
    "Advanced command framework without plugin.yml",
    "Auto-updating configuration with comments",
    "Database abstraction (MySQL, SQLite, HikariCP)",
    "NBT manipulation API",
    "Packet utilities for cross-version compatibility",
    "Conversation system for player interactions",
    "Plugin integration hooks (Vault, Citizens, Discord, etc.)",
    "Hologram and scoreboard APIs",
    "Region and visualization tools",
    "BungeeCord messaging support"
